# SQLite Database (Embedded - No setup needed!)
# Database file will be created automatically at: server/crm_database.sqlite
# No additional configuration needed

# JWT Configuration
JWT_SECRET=your_ultra_secure_jwt_secret_key_change_this_in_production_12345
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
